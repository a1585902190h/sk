# FastAPI Configuration
DEBUG=True
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=Football Match Predictor API
API_VERSION=1.0.0

# Database Configuration
# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/football_predictor
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=football_predictor

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# API Keys
FOOTBALL_DATA_API_KEY=your_api_key_here
ESPN_API_KEY=your_api_key_here
RAPIDAPI_KEY=your_api_key_here

# Data Fetching
DATA_FETCH_INTERVAL=3600  # seconds (1 hour)
DATA_SOURCES=football_data,espn,rapidapi,web_scraper
ENABLE_AUTO_UPDATE=True

# Model Configuration
DEFAULT_MODEL=ensemble
MODELS_TO_USE=elo,logistic_regression,random_forest,xgboost,lstm,ensemble

# Model Training
TRAIN_INTERVAL=604800  # seconds (1 week)
TRAIN_TEST_SPLIT=0.8
VALIDATION_SPLIT=0.2
RANDOM_STATE=42

# Feature Engineering
FEATURE_WINDOW_SIZE=10  # matches to look back
INCLUDE_PLAYER_STATS=True
INCLUDE_WEATHER_DATA=False

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log
ENABLE_SENTRY=False
SENTRY_DSN=

# CORS & Security
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=*
ENABLE_HTTPS=False
SECRET_KEY=your_secret_key_here

# Email Configuration (for alerts)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_password
ALERT_EMAIL=alerts@example.com
ENABLE_EMAIL_ALERTS=False

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Caching
ENABLE_CACHE=True
CACHE_BACKEND=redis

# Performance
ENABLE_PROFILING=False
SLOW_QUERY_LOG_TIME=1000  # milliseconds
